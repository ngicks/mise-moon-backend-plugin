[Unit]
Description=Build the MoonBit sandbox image for mise-moon-backend-plugin

[Build]
ImageTag=localhost/ngicks/moonbit-installer-sandbox:ubuntu-latest
File=ubuntu.Containerfile
SetWorkingDirectory=unit
Pull=newer
Secret=id=certs,src=/etc/ssl/certs/ca-certificates.crt

[Install]
WantedBy=default.target
